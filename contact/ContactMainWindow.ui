  <property name="styleSheet">
   <string notr="true">/* ===== GLOBAL FONT ===== */
* {
    font-family: &quot;Playfair Display&quot;;
}

/* ===== PAGE BACKGROUND ===== */
QMainWindow {
    background-color: #F5EBDD;
}

/* ===== CONTACT FRAME (KHUNG NGOÀI) ===== */
#contactFrame {
    background-color: #F8F1E8;
    border: 3px solid #D9A577;   /* viền caramel */
    border-radius: 28px;         /* bo góc lớn */
    padding: 24px;
}

/* ===== CỘT TRÁI / CỘT PHẢI ===== */
#contactLeft {
    background-color: transparent;
}

#contactRight {
    background-color: transparent;
}

/* ===== TIÊU ĐỀ CONTACT ===== */
#contactTitle {
    color: #6B3F2A;
    font-size: 32px;
    font-weight: bold;
    
}

/* ===== TÊN STUDIO ===== */
#studioNameLabel {
    color: #6B3F2A;
    font-size: 24px;
    font-weight: bold;
}

/* ===== CÁC DÒNG THÔNG TIN LIÊN HỆ ===== */
#emailLabel,
#phoneLabel,
#addressLabel,
#hoursLabel,
#hoursValueLabel {
    color: #6B3F2A;
    font-size: 16px;
}

/* In đậm riêng dòng &quot;Working Hours:&quot; cho giống heading nhỏ */
#hoursLabel {
    font-weight: bold;
}

/* ===== NÚT BOOK NOW ===== */
#contactBookButton {
    color: #FFFFFF;
    background-color: #B8845E;   /* caramel */
    border-radius: 22px;
    padding: 10px 32px;
    font-size: 18px;
    border: 2px solid #A36F4B;
}

#contactBookButton:hover {
    background-color: #9C6A45;
    border-color: #8C5F3E;
}

/* ===== ẢNH BÊN PHẢI ===== */
#contactImage {
    background-color: #FFF9F3;
    border: 2px solid #D9A577;
    border-radius: 0px;
}</string>

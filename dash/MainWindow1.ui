  <property name="styleSheet">
   <string notr="true">/* ===== GLOBAL FONT ===== */
* {
    font-family: &quot;Playfair Display&quot;;
}



/* ===== HEADER BAR ===== */
#headerFrame {
    background-color: #B8845E;
}

/* ===== PHONE BOX ===== */
#phoneFrame {
    background-color: #E6CBB2;
    border-radius: 6px;
}

/* ===== DASHBOARD TITLE ===== */
#titleLabel {
    color: #6B3F2A;
    font-size: 34px;
    font-weight: bold;
}

/* ===== MAIN CONTAINER ===== */
#mainContainer {
    background-color: #F8F1E8;
    border: 2px solid #C28B5D;
    border-radius: 20px;
}

/* ===== TOP STAT CARDS ===== */
#cardFrame_1,
#cardFrame_2,
#cardFrame_3 {
    background-color: #F8F1E8;
    border: 2px solid #D1A37A;
    border-radius: 15px;
    padding: 15px;
}

/* ===== STAT CARD TITLES ===== */
#title_1,
#title_2,
#title_3 {
    color: #5A3220;
    font-size: 16px;
    font-weight: bold;
}

/* ===== BIG NUMBER ===== */
#bigNumber_1,
#bigNumber_2,
#bigNumber_3 {
    color: #5A3220;
    font-size: 28px;
    font-weight: bold;
}

/* ===== SMALL TEXT ===== */
#smallText_1,
#smallText_2,
#smallText_3 {
    color: #8C5B3E;
    font-size: 14px;
}

/* ===== CHART FRAMES ===== */
#chartFrame_1,
#chartFrame_2 {
    background-color: #F8F1E8;
    border: 2px dashed #C28B5D;
    border-radius: 15px;
    padding: 15px;
}

/* ===== CHART TITLE ===== */
#chartTitle_1,
#chartTitle_2 {
    color: #5A3220;
    font-size: 20px;
    font-weight: bold;
}

/* ===== CHART SUBTEXT ===== */
#chartSub_1,
#chartSub_2 {
    color: #8C5B3E;
    font-size: 14px;
}
QMainWindow {
    background-color: #F5EBDD;
}

#footerFrame {
    background-color: #A36F4B;
}

</string>
  </property>
